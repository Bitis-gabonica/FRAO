# FRAO — directives serveur OVH (Apache)
# But : empecher les navigateurs de servir une version perimee du site
# apres une mise a jour. Le navigateur reverifie a chaque visite.

<IfModule mod_headers.c>
  # HTML, CSS, JS : revalider a chaque requete (304 si inchange, sinon nouveau contenu)
  <FilesMatch "\.(html|htm|css|js)$">
    Header set Cache-Control "no-cache, must-revalidate"
    Header unset Expires
    Header unset Pragma
  </FilesMatch>

  # Images : cache 30 jours (elles changent rarement, gain de perf)
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

# Fallback si mod_headers est indisponible (peu probable chez OVH)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 0 seconds"
  ExpiresByType application/javascript "access plus 0 seconds"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
</IfModule>

# Securite : empecher l'acces direct aux dossiers de dev qui auraient ete uploades
RedirectMatch 404 /\.git(/|$)
RedirectMatch 404 /\.claude(/|$)
RedirectMatch 404 /docs(/|$)
